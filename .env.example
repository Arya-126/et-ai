# Graph backend: "neo4j" (primary) or "networkx" (no-Docker fallback).
# If neo4j is selected but unreachable at startup, the app auto-falls-back to networkx.
GRAPH_BACKEND=neo4j

# Neo4j (matches docker-compose.yml)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=fraudpass

# Ollama (local LLM, free, offline)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
# Set to a number of seconds; classifier degrades to rules-only if Ollama is slow/down.
OLLAMA_TIMEOUT=30

# CORS origins for the two front ends (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
